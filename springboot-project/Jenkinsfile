pipeline {
    agent any
    tools {
        // 告訴 Jenkins 這個 Pipeline 要套用我們剛剛在後台設定好名為 'local-maven' 的 Maven 工具
        maven 'local-maven' 
    }
    environment {
        // 這裡改成你原本 backend-deploy.yaml 裡面寫的 image 名稱：beibei860429/springboot-api
        DOCKER_HUB_REGISTRY = 'beibei860429/springboot-api'
        GITHUB_CREDENTIALS_ID = 'github-token'
        DOCKER_CREDENTIALS_ID = 'dockerhub-pwd' // 這是你在 Jenkins 儲存的 Docker Hub 帳密憑證 ID

        // 安全修正：從 Jenkins 保險箱讀取，GitHub 上完全看不到密碼！
        AWS_ACCESS_KEY_ID     = credentials('aws-access-key')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-key')
        AWS_SESSION_TOKEN     = credentials('aws-session-token')
        AWS_DEFAULT_REGION    = 'ap-south-1'
    }
    stages {
        stage('Fetch Code') {
            steps {
                git branch: 'main', credentialsId: "${GITHUB_CREDENTIALS_ID}", url: 'https://github.com/beibei860429/pokeshop-fullstack.git'
            }
        }
        
        stage('Maven Build') {
            steps {
                dir('springboot-project') {
                    // 改成呼叫 Windows 本機安裝的實體 Maven 指令
                    bat 'mvn clean package -DskipTests'
                }
            }
        }
        
        stage('Docker Build & Push') {
            steps {
                dir('springboot-project') {
                    // 🎯 使用 withCredentials 安全地在 bat 中取得 Docker Hub 的帳號密碼
                    withCredentials([usernamePassword(credentialsId: "${DOCKER_CREDENTIALS_ID}", usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASSWORD')]) {
                        script {
                            def imageTag = "v_${env.BUILD_NUMBER}"
                            
                            // 1. 登入 Docker Hub (使用標準 Windows 批次指令)
                            bat "docker login -u %DOCKER_USER% -p %DOCKER_PASSWORD%"
                            
                            // 2. 打包映像檔
                            bat "docker build -t ${DOCKER_HUB_REGISTRY}:${imageTag} -t ${DOCKER_HUB_REGISTRY}:latest ."
                            
                            // 3. 推送到 Docker Hub
                            bat "docker push ${DOCKER_HUB_REGISTRY}:${imageTag}"
                            bat "docker push ${DOCKER_HUB_REGISTRY}:latest"
                        }
                    }
                }
            }
        }

        // 核心修改：移除原本的 kubectl apply，改為更新 GitOps 部署倉庫的 YAML 設定
        stage('Update GitOps Manifest') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'github-token', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_TOKEN')]) {
                    script {
                        def imageTag = "v_${env.BUILD_NUMBER}"
                        
                        // 這裡用 """，但把內部的反斜線 \ 全數消滅，改用正斜線 / 或是雙斜線 \\ 轉義
                        powershell """
                            # 移除舊的資料夾（若存在）
                            if (Test-Path -Path "pokeshop-gitops") { Remove-Item -Recurse -Force "pokeshop-gitops" }

                            # 克隆倉庫（\$env:GIT_TOKEN 用反斜線轉義是正確的，因為那是保留給 PowerShell 的變數）
                            git clone https://\$env:GIT_TOKEN@github.com/beibei860429/pokeshop-gitops.git
                            
                            cd pokeshop-gitops
                            
                            git config user.name "Jenkins CI"
                            git config user.email "jenkins@cicd.com"

                            # 關鍵修正：把原本的 .\\ 改成正斜線 ./ 或者直接寫檔名，徹底避開 Groovy 語法衝突
                            if (Test-Path -Path "/apps/backend-deploy.yaml") {
                                (Get-Content ./apps/backend-deploy.yaml) -replace 'springboot-api:.*', "springboot-api:${imageTag}" | Set-Content ./apps/backend-deploy.yaml
                                
                                git add ./apps/backend-deploy.yaml
                                git commit -m "chore: Jenkins auto update backend image tag to ${imageTag} [skip ci]"
                                git push origin main
                            } else {
                                Write-Error "找不到 /apps/backend-deploy.yaml 檔案！"
                            }
                        """
                    }
                }
            }
        }
    }
    // SNS 推播區塊
    post {
        success {
            script {
                // 當整個 Pipeline 成功走完綠燈，呼叫 AWS CLI 將訊息推給 SNS
                powershell """
                    aws sns publish --topic-arn "${env.SNS_TOPIC_ARN}" `
                        --subject "【Jenkins 通知】Pokeshop 後端已完成部署！(Build #${env.BUILD_NUMBER})" `
                        --message "嗨 Beibei！Pokeshop 後端專案已成功通過 CI/CD 流水線。最新映像檔標籤為 v_${env.BUILD_NUMBER}，並已成功同步至 GitOps 倉庫。請前往 ArgoCD 查閱 EKS 叢集滾動更新狀態！"
                """
            }
        }
        
        failure {
            script {
                // 💡 貼心擴充：如果中間有任何階段（如編譯、打包）失敗，也發 SNS 警告你
                powershell """
                    aws sns publish --topic-arn "${env.SNS_TOPIC_ARN}" `
                        --subject "【Jenkins 警報】Pokeshop 後端部署失敗！(Build #${env.BUILD_NUMBER})" `
                        --message "注意：Pokeshop 後端專案在建置中途發生錯誤（Build #${env.BUILD_NUMBER} 失敗）。請立刻登入 Jenkins 查閱 Console Output 進行排錯！"
                """
            }
        }
    }
}